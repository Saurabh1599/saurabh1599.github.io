---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main class="min-h-screen flex flex-col items-center w-full">
        <nav
            class="fixed top-0 w-full z-50 px-8 py-5 flex justify-between items-center bg-white/70 dark:bg-black/80 backdrop-blur-md border-b border-slate-200/50 dark:border-white/10 transition-colors duration-500"
        >
            <div class="flex justify-start relative z-50">
                <h1
                    class="text-xl font-medium tracking-tight text-slate-900 dark:text-white"
                >
                    Saurabh Sawant
                </h1>
            </div>

            <div
                class="hidden lg:flex justify-center items-center text-xs tracking-[0.2em] uppercase font-medium text-slate-500 dark:text-slate-400 space-x-2"
            >
                <a
                    href="#work"
                    class="px-4 py-2 border border-slate-200 dark:border-white/10 rounded-full hover:border-teal-500 dark:hover:border-amber-300 hover:text-slate-900 dark:hover:text-white transition-all"
                    >Projects</a
                >
                <a
                    href="#about"
                    class="px-4 py-2 border border-slate-200 dark:border-white/10 rounded-full hover:border-teal-500 dark:hover:border-amber-300 hover:text-slate-900 dark:hover:text-white transition-all"
                    >About</a
                >
                <a
                    href="#experience"
                    class="px-4 py-2 border border-slate-200 dark:border-white/10 rounded-full hover:border-teal-500 dark:hover:border-amber-300 hover:text-slate-900 dark:hover:text-white transition-all"
                    >Experience</a
                >
                <a
                    href="#publications"
                    class="px-4 py-2 border border-slate-200 dark:border-white/10 rounded-full hover:border-teal-500 dark:hover:border-amber-300 hover:text-slate-900 dark:hover:text-white transition-all"
                    >Publications</a
                >
            </div>

            <div class="flex justify-end items-center space-x-4 md:space-x-6 relative z-50">
                <div
                    class="hidden lg:flex space-x-6 text-xs tracking-[0.2em] uppercase font-medium text-slate-500 dark:text-slate-400"
                >
                    <a
                        href="https://github.com/Saurabh1599"
                        target="_blank"
                        class="hover:text-teal-600 dark:hover:text-amber-300 transition-colors"
                        >GitHub ↗</a
                    >
                    <a
                        href="/CV.pdf"
                        target="_blank"
                        class="hover:text-teal-600 dark:hover:text-amber-300 transition-colors"
                        >CV ↗</a
                    >
                </div>

                <div
                    class="h-4 w-[1px] bg-slate-300 dark:bg-white/20 hidden lg:block"
                >
                </div>

                <button
                    id="themeToggle"
                    class="text-slate-400 hover:text-teal-600 dark:hover:text-amber-300 transition-colors"
                    aria-label="Toggle Dark Mode"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5 hidden dark:block"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
                        ></path></svg
                    >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5 block dark:hidden"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
                        ></path></svg
                    >
                </button>

                <button
                    id="mobileMenuToggle"
                    class="block lg:hidden text-slate-600 dark:text-slate-300 hover:text-teal-600 dark:hover:text-amber-300 transition-colors ml-2"
                    aria-label="Toggle Mobile Menu"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-6 w-6"
                        id="menuIconOpen"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-6 w-6 hidden"
                        id="menuIconClose"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </nav>

        <div id="mobileMenu" class="fixed inset-0 z-40 bg-white/95 dark:bg-black/95 backdrop-blur-lg flex-col items-center justify-center space-y-8 hidden lg:hidden opacity-0 transition-opacity duration-300 pt-16">
            <div class="flex flex-col items-center space-y-8 text-lg tracking-[0.2em] uppercase font-medium text-slate-800 dark:text-slate-200">
                <a href="#work" class="mobile-link hover:text-teal-600 dark:hover:text-amber-300 transition-colors">Projects</a>
                <a href="#about" class="mobile-link hover:text-teal-600 dark:hover:text-amber-300 transition-colors">About</a>
                <a href="#experience" class="mobile-link hover:text-teal-600 dark:hover:text-amber-300 transition-colors">Experience</a>
                <a href="#publications" class="mobile-link hover:text-teal-600 dark:hover:text-amber-300 transition-colors">Publications</a>
            </div>
            
            <div class="h-[1px] w-16 bg-slate-200 dark:bg-white/10"></div>
            
            <div class="flex flex-col items-center space-y-8 text-lg tracking-[0.2em] uppercase font-medium text-slate-800 dark:text-slate-200">
                <a href="https://github.com/Saurabh1599" target="_blank" class="mobile-link hover:text-teal-600 dark:hover:text-amber-300 transition-colors">GitHub ↗</a>
                <a href="/CV.pdf" target="_blank" class="mobile-link hover:text-teal-600 dark:hover:text-amber-300 transition-colors">CV ↗</a>
            </div>
        </div>

        <section
            class="w-full max-w-[90rem] px-8 pt-[32vh] pb-32 flex flex-col items-start"
        >
            <p
                class="text-sm md:text-base tracking-[0.2em] text-teal-700 dark:text-amber-300 font-medium uppercase mb-6"
            >
                M.Sc. Mechatronics · TUHH · Hamburg
            </p>
            <h2
                class="text-6xl md:text-8xl font-light text-slate-900 dark:text-white leading-[1.05] tracking-tighter"
            >
                this is where <br />
                <span
                    class="font-medium text-teal-700 dark:text-amber-300 tracking-tight"
                    >hardware</span
                > meets <br />
                intelligence.
            </h2>
        </section>

        <section
            id="work"
            class="w-full max-w-[90rem] px-8 py-24 border-t border-slate-200 dark:border-white/10 scroll-mt-24 transition-colors duration-500"
        >
            <h3
                class="text-sm tracking-[0.2em] text-teal-600 dark:text-amber-300 uppercase mb-12 font-semibold"
            >
                Selected Works
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <a
                    href="/projects/nav2-rover"
                    class="group flex flex-col bg-white dark:bg-[#0a0a0a] border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md dark:shadow-none rounded-2xl overflow-hidden hover:border-teal-400 dark:hover:border-amber-300/50 transition-all duration-300 hover:-translate-y-1"
                >
                    <div
                        class="w-full aspect-[9/16] max-h-[400px] relative overflow-hidden bg-slate-50 dark:bg-black"
                    >
                        <video
                            src="/Janus_video.mp4"
                            autoplay
                            loop
                            muted
                            playsinline
                            class="w-full h-full object-cover opacity-90 dark:opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                        ></video>
                    </div>
                    <div class="p-8 flex flex-col flex-grow">
                        <h4
                            class="text-xl font-medium tracking-tight text-slate-900 dark:text-white mb-3"
                        >
                            Articulated Motion Planning (Nav2)
                        </h4>
                        <p
                            class="text-slate-600 dark:text-slate-300 text-base leading-relaxed mb-8 flex-grow"
                        >
                            Adapting the ROS2 Nav2 framework for dual-body
                            rovers integrating custom motion models and
                            hinge-aware collision checking.
                        </p>
                        <div
                            class="flex flex-wrap gap-2 text-xs tracking-[0.1em] uppercase font-medium text-slate-500 dark:text-slate-400"
                        >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >ROS2</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Nav2</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Motion Planning</span
                            >
                        </div>
                    </div>
                </a>

                <a
                    href="/projects/multi-robot-task-planning"
                    class="group flex flex-col bg-white dark:bg-[#0a0a0a] border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md dark:shadow-none rounded-2xl overflow-hidden hover:border-teal-400 dark:hover:border-amber-300/50 transition-all duration-300 hover:-translate-y-1"
                >
                    <div
                        class="w-full aspect-[9/16] max-h-[400px] relative overflow-hidden bg-slate-50 dark:bg-black"
                    >
                        <img
                            src="/IDOGS.PNG"
                            alt="Multi-Robot Task Planning"
                            class="w-full h-full object-cover opacity-90 dark:opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                        />
                    </div>
                    <div class="p-8 flex flex-col flex-grow">
                        <h4
                            class="text-xl font-medium tracking-tight text-slate-900 dark:text-white mb-3"
                        >
                            Multi-Robot Task Planning
                        </h4>
                        <p
                            class="text-slate-600 dark:text-slate-300 text-base leading-relaxed mb-8 flex-grow"
                        >
                            Dynamic Behavior-Tree framework for autonomous
                            inspection with multiple quadruped robots via ROS
                            namespaces.
                        </p>
                        <div
                            class="flex flex-wrap gap-2 text-xs tracking-[0.1em] uppercase font-medium text-slate-500 dark:text-slate-400"
                        >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Task Planning</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Behavior Trees</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >ROS</span
                            >
                        </div>
                    </div>
                </a>

                <a
                    href="/projects/needle-placement"
                    class="group flex flex-col bg-white dark:bg-[#0a0a0a] border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md dark:shadow-none rounded-2xl overflow-hidden hover:border-teal-400 dark:hover:border-amber-300/50 transition-all duration-300 hover:-translate-y-1"
                >
                    <div
                        class="w-full aspect-[9/16] max-h-[400px] relative overflow-hidden bg-slate-50 dark:bg-black"
                    >
                        <video
                            src="/RNM_2.mp4"
                            autoplay
                            loop
                            muted
                            playsinline
                            class="w-full h-full object-cover opacity-90 dark:opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                        ></video>
                    </div>
                    <div class="p-8 flex flex-col flex-grow">
                        <h4
                            class="text-xl font-medium tracking-tight text-slate-900 dark:text-white mb-3"
                        >
                            Image-Guided Needle Placement
                        </h4>
                        <p
                            class="text-slate-600 dark:text-slate-300 text-base leading-relaxed mb-8 flex-grow"
                        >
                            Implemented trajectory planning and kinematics for a
                            Franka Panda robotic arm to perform precise
                            image-guided needle insertions.
                        </p>
                        <div
                            class="flex flex-wrap gap-2 text-xs tracking-[0.1em] uppercase font-medium text-slate-500 dark:text-slate-400"
                        >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >ROS</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Trajectory Planning</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Kinematics</span
                            >
                        </div>
                    </div>
                </a>

                <a
                    href="/projects/non-visual-perception"
                    class="group flex flex-col bg-white dark:bg-[#0a0a0a] border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md dark:shadow-none rounded-2xl overflow-hidden hover:border-teal-400 dark:hover:border-amber-300/50 transition-all duration-300 hover:-translate-y-1"
                >
                    <div
                        class="w-full aspect-[9/16] max-h-[400px] relative overflow-hidden bg-slate-50 dark:bg-black"
                    >
                        <video
                            src="/AGV.mp4"
                            autoplay
                            loop
                            muted
                            playsinline
                            class="w-full h-full object-cover opacity-90 dark:opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                        ></video>
                    </div>
                    <div class="p-8 flex flex-col flex-grow">
                        <h4
                            class="text-xl font-medium tracking-tight text-slate-900 dark:text-white mb-3"
                        >
                            Non-Visual Perception System
                        </h4>
                        <p
                            class="text-slate-600 dark:text-slate-300 text-base leading-relaxed mb-8 flex-grow"
                        >
                            Built a non-visual perception stack for a UGV using
                            ultrasonic, force, and IMU sensors for real-time
                            motion adaptation.
                        </p>
                        <div
                            class="flex flex-wrap gap-2 text-xs tracking-[0.1em] uppercase font-medium text-slate-500 dark:text-slate-400"
                        >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >RasPi</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Python</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Sensors</span
                            >
                        </div>
                    </div>
                </a>

                <a
                    href="/projects/flapwheel-anomaly-detection"
                    class="group flex flex-col bg-white dark:bg-[#0a0a0a] border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md dark:shadow-none rounded-2xl overflow-hidden hover:border-teal-400 dark:hover:border-amber-300/50 transition-all duration-300 hover:-translate-y-1"
                >
                    <div
                        class="w-full aspect-[9/16] max-h-[400px] relative overflow-hidden bg-slate-50 dark:bg-black"
                    >
                        <img
                            src="/Flapwheel_1.png"
                            alt="Flapwheel Anomaly Detection"
                            class="w-full h-full object-cover opacity-90 dark:opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                        />
                    </div>
                    <div class="p-8 flex flex-col flex-grow">
                        <h4
                            class="text-xl font-medium tracking-tight text-slate-900 dark:text-white mb-3"
                        >
                            Flapwheel Anomaly Detection
                        </h4>
                        <p
                            class="text-slate-600 dark:text-slate-300 text-base leading-relaxed mb-8 flex-grow"
                        >
                            Convolutional Autoencoder (CAE) based anomaly
                            detection system to inspect flap wheels for
                            structural defects.
                        </p>
                        <div
                            class="flex flex-wrap gap-2 text-xs tracking-[0.1em] uppercase font-medium text-slate-500 dark:text-slate-400"
                        >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Computer Vision</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Autoencoder</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >PyTorch</span
                            >
                        </div>
                    </div>
                </a>

                <a
                    href="/projects/maze-solver"
                    class="group flex flex-col bg-white dark:bg-[#0a0a0a] border border-slate-200 dark:border-white/10 shadow-sm hover:shadow-md dark:shadow-none rounded-2xl overflow-hidden hover:border-teal-400 dark:hover:border-amber-300/50 transition-all duration-300 hover:-translate-y-1"
                >
                    <div
                        class="w-full aspect-[9/16] max-h-[400px] relative overflow-hidden bg-slate-50 dark:bg-black"
                    >
                        <video
                            src="/Lego.MP4"
                            autoplay
                            loop
                            muted
                            playsinline
                            class="w-full h-full object-cover opacity-90 dark:opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                        ></video>
                    </div>
                    <div class="p-8 flex flex-col flex-grow">
                        <h4
                            class="text-xl font-medium tracking-tight text-slate-900 dark:text-white mb-3"
                        >
                            Autonomous Maze Solver
                        </h4>
                        <p
                            class="text-slate-600 dark:text-slate-300 text-base leading-relaxed mb-8 flex-grow"
                        >
                            Developed an autonomous maze-solving LEGO Mindstorms
                            robot using Java and object-oriented programming
                            principles.
                        </p>
                        <div
                            class="flex flex-wrap gap-2 text-xs tracking-[0.1em] uppercase font-medium text-slate-500 dark:text-slate-400"
                        >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Java</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >OOP</span
                            >
                            <span
                                class="px-3 py-1 border border-slate-200 dark:border-white/10 rounded-full"
                                >Sensors</span
                            >
                        </div>
                    </div>
                </a>
            </div>
        </section>

        <section
            id="about"
            class="w-full max-w-[90rem] px-8 py-24 border-t border-slate-200 dark:border-white/10 scroll-mt-24 transition-colors duration-500"
        >
            <div class="grid grid-cols-1 md:grid-cols-12 gap-16 items-center">
                <div class="md:col-span-5 lg:col-span-5">
                    <div
                        class="p-2 bg-white dark:bg-[#111] border border-slate-200 dark:border-white/10 rounded-2xl shadow-sm"
                    >
                        <img
                            src="/profile.JPG"
                            alt="Saurabh Sawant"
                            class="w-full aspect-[3/4] object-cover grayscale hover:grayscale-0 transition-all duration-700 rounded-xl"
                        />
                    </div>
                </div>
                <div
                    class="md:col-span-7 lg:col-span-7 lg:col-start-6 flex flex-col justify-center"
                >
                    <h3
                        class="text-sm tracking-[0.2em] text-teal-600 dark:text-amber-300 uppercase mb-8 font-semibold"
                    >
                        About Me
                    </h3>
                    <div
                        class="space-y-6 text-slate-600 dark:text-slate-300 leading-relaxed text-lg text-justify"
                    >
                        <p>
                            My journey into robotics did not start in a computer
                            lab. It began on the manufacturing floor at Suzuki.
                            Coming from a mechanical engineering background, I
                            spent my time surrounded by heavy industrial robots
                            building cars. That exposure sparked a deep
                            curiosity, as I did not just want to know how they
                            moved mechanically. I wanted to understand the logic
                            that drove their decisions. What started as pure
                            curiosity quickly accelerated into a dedicated
                            career path.
                        </p>
                        <p>
                            Currently pursuing my Master's in Mechatronics at
                            TUHH in Hamburg, my focus sits firmly at the
                            intersection of robotics and artificial
                            intelligence. I am deeply interested in Physical AI
                            and the challenge of building systems that bridge
                            the gap between high-level intelligent reasoning and
                            robust real-world execution. Rather than isolating
                            myself to a single software node, my ultimate goal
                            is to master the complete robotics pipeline. From
                            perception and spatial comprehension down to
                            low-level navigation and control, I want to
                            understand the entire autonomy stack.
                        </p>
                        <p>
                            Beyond the lab, I stay active by playing football
                            and love exploring historically significant places
                            whenever I travel. I also enjoy cooking and am an
                            avid listener of podcasts, diving into a wide array
                            of topics that span history, food, travel, science,
                            and robotics.
                        </p>
                    </div>
                    <div class="mt-10">
                        <a
                            href="#contact"
                            class="px-6 py-3 bg-slate-900 text-white dark:bg-white dark:text-black text-xs tracking-[0.2em] uppercase font-medium rounded-full hover:bg-teal-700 dark:hover:bg-amber-300 transition-colors"
                            >Let's Connect</a
                        >
                    </div>
                </div>
            </div>
        </section>

        <section
            id="experience"
            class="w-full max-w-[90rem] px-8 py-24 border-t border-slate-200 dark:border-white/10 scroll-mt-24 transition-colors duration-500"
        >
            <h3
                class="text-sm tracking-[0.2em] text-teal-600 dark:text-amber-300 uppercase mb-12 font-semibold"
            >
                Experience
            </h3>

            <div
                class="space-y-16 border-l border-slate-200 dark:border-white/10 ml-2 pl-10 max-w-4xl"
            >
                <div class="relative">
                    <div
                        class="absolute -left-[45px] top-1.5 h-2.5 w-2.5 rounded-full bg-teal-600 dark:bg-amber-300 ring-4 ring-white dark:ring-black"
                    >
                    </div>
                    <p
                        class="text-xs md:text-sm tracking-[0.2em] text-teal-700 dark:text-amber-300 uppercase mb-3 font-medium"
                    >
                        11/2025 — 02/2026
                    </p>
                    <h4
                        class="text-xl md:text-2xl font-medium tracking-tight text-slate-900 dark:text-white"
                    >
                        Student Tutor · IDAC, TUHH
                    </h4>
                    <p
                        class="text-slate-600 dark:text-slate-300 text-base mt-3 leading-relaxed"
                    >
                        Assisted in teaching the Bauinformatik Datenbanken
                        seminar, guiding students through database design, ER
                        modeling, and SQL fundamentals.
                    </p>
                </div>

                <div class="relative">
                    <div
                        class="absolute -left-[45px] top-1.5 h-2.5 w-2.5 rounded-full bg-slate-300 dark:bg-slate-600 ring-4 ring-white dark:ring-black"
                    >
                    </div>
                    <p
                        class="text-xs md:text-sm tracking-[0.2em] text-slate-500 uppercase mb-3 font-medium"
                    >
                        07/2024 — 03/2025 &amp; 08/2025 — 10/2025
                    </p>
                    <h4
                        class="text-xl md:text-2xl font-medium tracking-tight text-slate-900 dark:text-white"
                    >
                        Student Research Assistant · IDAC, TUHH
                    </h4>
                    <p
                        class="text-slate-600 dark:text-slate-300 text-base mt-3 leading-relaxed"
                    >
                        Setting up simulation environments for Husky UGVs and
                        UR5e arms, and researching Behavior Trees for
                        multi-robot task assignment.
                    </p>
                </div>

                <div class="relative">
                    <div
                        class="absolute -left-[45px] top-1.5 h-2.5 w-2.5 rounded-full bg-slate-300 dark:bg-slate-600 ring-4 ring-white dark:ring-black"
